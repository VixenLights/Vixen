<local:OpenTkPreviewUserControl x:Class="VixenApplication.SetupDisplay.Views.PreviewSetup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VixenApplication.SetupDisplay.Views"
			 xmlns:glWpfControl="clr-namespace:OpenTK.Wpf;assembly=GLWpfControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

	<Control.Resources>
		<Style x:Key="DisabledAwareTextBlock" TargetType="TextBlock">
			<Setter Property="Foreground" Value="White" />
			<Style.Triggers>
				<Trigger Property="IsEnabled" Value="False">
					<Setter Property="Foreground" Value="Gray" />
					<Setter Property="Opacity" Value="0.6" />
				</Trigger>
			</Style.Triggers>
		</Style>
	</Control.Resources>

	<Grid>
		<DockPanel>
			<ToolBar DockPanel.Dock="Top">
				<Button Command="{Binding DeletePreviewProp}" ToolTip="Remove Preview Prop">
					<Image Source="pack://application:,,,/Resources;component/Resources/delete_32.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding SelectBackgroundImage}" ToolTip="Select Background Image">
					<Image Source="BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<StackPanel Orientation="Vertical">
					
					<Slider Width="150"
					Minimum="0"
					Maximum="1"
					 Value="{Binding BackgroundBrightness}"
					TickFrequency="0.1"					
					IsSnapToTickEnabled="True" 
					IsEnabled="{Binding BackgroundBrightnessEnabled}"
					ToolTip="Background Brightness"/>
					<TextBlock Text="Background Brightness" 
						Style="{StaticResource DisabledAwareTextBlock}"
						IsEnabled="{Binding BackgroundBrightnessEnabled}"
						VerticalAlignment="Center"
						Margin="0,0,5,0" />
				</StackPanel>
				<ToggleButton IsChecked="{Binding DisplayPreviewDrawingEngine.IsSelectMode}" ToolTip="Select Entire Prop">
					<Image Source="buttonContainsSelect.png" Width="32" Height="32"/>
				</ToggleButton>
				<ToggleButton IsChecked="{Binding DisplayPreviewDrawingEngine.IsPartialSelectMode}" ToolTip="Select Partial Prop">
					<Image Source="buttonPartialSelect.png" Width="32" Height="32"/>
				</ToggleButton>
				<ToggleButton IsChecked="{Binding DisplayPreviewDrawingEngine.IsPanMode}" ToolTip="Pan Preview">
					<Image Source="buttonSelect.png" Width="32" Height="32"/>
				</ToggleButton>
				<Button Command="{Binding Lock}" ToolTip="Lock Props">
					<Image Source="pack://application:,,,/Resources;component/Resources/locked.png" Width="32" Height="32"/>					
				</Button>
				<Button Command="{Binding Unlock}" ToolTip="Unlock Props">
					<Image Source="pack://application:,,,/Resources;component/Resources/unlocked.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding UnlockAll}" ToolTip="Unlock All Props">
					<Image Source="pack://application:,,,/Resources;component/Resources/unlockedAll.png" Width="32" Height="32"/>
				</Button>
				 				 				 				 				 				 				 				 				
				<Button Command="{Binding MatchProperties}" ToolTip="Make Selected Props Same Size">
					<Image Source="pack://application:,,,/Resources;component/buttonMatchProperties.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding DistributeHorizontally}" ToolTip="Distribute Props Horizontally">
					<Image Source="pack://application:,,,/Resources;component/buttonDistributeHorizontal.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding DistributeVertically}" ToolTip="Distribute Props Vertically">
					<Image Source="pack://application:,,,/Resources;component/buttonDistributeVertical.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding AlignVertically}" ToolTip="Align Props Vertically">
					<Image Source="pack://application:,,,/Resources;component/buttonAlignHorizMid.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding AlignHorizontally}" ToolTip="Align Props Horizontally">
					<Image Source="pack://application:,,,/Resources;component/buttonAlignVertMid.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding AlignLeft}" ToolTip="Align Props Left">
					<Image Source="pack://application:,,,/Resources;component/buttonAlignLeft.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding AlignRight}" ToolTip="Align Props Right">
					<Image Source="pack://application:,,,/Resources;component/buttonAlignRight.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding AlignTop}" ToolTip="Align Props Top">
					<Image Source="pack://application:,,,/Resources;component/buttonAlignTop.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
				<Button Command="{Binding AlignBottom}" ToolTip="Align Props Bottom">
					<Image Source="pack://application:,,,/Resources;component/buttonAlignBottom.BackgroundImage.png" Width="32" Height="32"/>
				</Button>
			</ToolBar>
			<glWpfControl:GLWpfControl
				x:Name="OpenTkControlPreview" 							
				Render="OpenTkControlPreview_OnRender"
				SizeChanged="OpenTkControlPreview_SizeChanged"
				MouseDown="OpenTkControlPreview_MouseDown"
				MouseMove="OpenTkControlPreview_MouseMove"
				MouseUp="OpenTkControlPreview_MouseUp"
				Loaded="OpenTkControlPreview_Loaded"
				MouseWheel="OpenTkControlPreview_MouseWheel"
				KeyDown="OpenTkControlPreview_KeyDown"
				KeyUp="OpenTkControlPreview_KeyUp"
				Focusable="True">
				<glWpfControl:GLWpfControl.ContextMenu>
					<ContextMenu>
						<MenuItem Header="Center Preview"                          ToolTip="Repositions the viewpoint to the center of the preview." Command="{Binding DisplayPreviewCenter}"/>
						<MenuItem Header="Enable Light Scaling" IsCheckable="True" ToolTip="Scales the light size as the camera is zoomed in or out." IsChecked="{Binding EnableLightScaling }"/>
					</ContextMenu>
				</glWpfControl:GLWpfControl.ContextMenu>
			</glWpfControl:GLWpfControl>
		</DockPanel>
	</Grid>
</local:OpenTkPreviewUserControl>
