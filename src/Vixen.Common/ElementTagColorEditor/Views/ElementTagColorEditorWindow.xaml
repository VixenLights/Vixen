<catel:Window x:Class="Common.ElementTagColorEditor.Views.ElementTagColorEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:catel="http://schemas.catelproject.com"
        xmlns:commonConverters="clr-namespace:Common.WPFCommon.Converters;assembly=WPFCommon"
        xmlns:viewModels="clr-namespace:Common.ElementTagColorEditor.ViewModels"
        d:DataContext="{d:DesignInstance viewModels:ElementTagColorEditorWindowViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008/design"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="260" Width="360" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" ShowInTaskbar="False" Background="{DynamicResource BackColorBrush}"
        CanCloseUsingEscape="True">

	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="pack://application:,,,/WPFCommon;component/Theme/Theme.xaml"/>
			</ResourceDictionary.MergedDictionaries>
			<commonConverters:ColorToSolidBrushConverter x:Key="ColorToSolidBrushConverter"/>
		</ResourceDictionary>
	</Window.Resources>

	<DockPanel Margin="12">
		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
			<Button Content="Save" Width="80" Margin="0,0,8,0" Command="{Binding OkCommand}" IsDefault="True"/>
			<Button Content="Cancel" Width="80" Command="{Binding CancelCommand}" IsCancel="True"/>
		</StackPanel>

		<ItemsControl ItemsSource="{Binding Tags}">
			<ItemsControl.ItemTemplate>
				<DataTemplate DataType="{x:Type viewModels:TagColorItem}">
					<Grid Margin="0,4,0,4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
						           Foreground="{DynamicResource ForeColorBrush}"/>
						<Rectangle Grid.Column="1" Width="32" Height="24" Cursor="Hand"
						           Stroke="{DynamicResource BorderColorBrush}" StrokeThickness="1"
						           Fill="{Binding Color, Converter={StaticResource ColorToSolidBrushConverter}}">
							<Rectangle.InputBindings>
								<MouseBinding Gesture="LeftDoubleClick" Command="{Binding PickColorCommand}"/>
							</Rectangle.InputBindings>
						</Rectangle>
					</Grid>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</DockPanel>
</catel:Window>
